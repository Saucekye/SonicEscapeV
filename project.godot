; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ESCAPE"
run/main_scene="uid://dtwtf3r7d23cv"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="uid://bofykrf10kutc"
config/icon="res://exeicon.png"
config/windows_native_icon="res://1-8dac9c05.ico"

[autoload]

Test="*res://Scripts/Level/test.gd"
GlobalCanvasLayer="*res://Scripts/UI/CanvasLayer.gd"
MusicManager="*res://Scripts/Level/Music.gd"
Pause="*res://misc/pause.tscn"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
Background="*res://Scripts/Level/Background.gd"
GlobalSignals="*res://Scripts/Global/GlobalSignals.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=720
window/size/mode=3
window/size/window_width_override=1600
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/trail_2d/plugin.cfg")

[global_group]

Player=""
Rings=""
Spring=""
Enemy=""
Playerattack=""
Rail=""
Camera=""
bind=""
InstaKill=""
active_player=""
item=""
AttractCam=""
enemyattack=""
Miku=""

[gui]

fonts/dynamic_fonts/use_oversampling=false
theme/default_font_antialiasing=0
theme/default_font_hinting=0
theme/default_font_subpixel_positioning=0
theme/default_font_generate_mipmaps=true
theme/custom_font="res://Fonts/diest64.ttf"

